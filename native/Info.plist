<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key><string>OpenVoiceFlow</string>
    <key>CFBundleDisplayName</key><string>OpenVoiceFlow</string>
    <key>CFBundleIdentifier</key><string>app.openvoiceflow</string>
    <key>CFBundleExecutable</key><string>OpenVoiceFlow</string>
    <key>CFBundleIconFile</key><string>OpenVoiceFlow.icns</string>
    <key>CFBundlePackageType</key><string>APPL</string>
    <key>CFBundleShortVersionString</key><string>0.4.1</string>
    <key>CFBundleVersion</key><string>2</string>
    <key>LSMinimumSystemVersion</key><string>14.0</string>
    <!-- Menu-bar agent: no Dock icon, no main window on launch. -->
    <key>LSUIElement</key><true/>
    <key>NSHighResolutionCapable</key><true/>
    <!-- TCC usage strings (shown in the OS consent dialogs). -->
    <key>NSMicrophoneUsageDescription</key>
    <string>OpenVoiceFlow uses the microphone to transcribe your voice while you dictate.</string>
    <!-- Sparkle in-app updates. The appcast is served from the website root. -->
    <key>SUFeedURL</key><string>https://openvoiceflow.vercel.app/appcast.xml</string>
    <key>SUEnableInstallerLauncherService</key><false/>
    <!-- Only check on launch/schedule, never auto-download silently. -->
    <key>SUScheduledCheckInterval</key><integer>86400</integer>
    <!--
      SUPublicEDKey: the EdDSA public key that verifies appcast signatures.
      This is LIVE — the keypair was generated, the private half is the repo
      secret SPARKLE_ED_PRIVATE_KEY, and the release pipeline
      (release-native.yml) signs each DMG's appcast with it. The published
      0.4.1 appcast is already signed against this key. DO NOT regenerate the
      keypair or change this value: existing installs verify updates against
      it, so a new key would break auto-update for every shipped copy.
    -->
    <key>SUPublicEDKey</key><string>PBw5H5WuZzXg4XrkOBSKF1aptFmpxjgesASYm5VridE=</string>
</dict>
</plist>
